@model LastCallMotorAuctions.API.Models.DashboardViewModel

@{
    ViewData["Title"] = "Buyer Dashboard";
}

<!-- Stats Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-2 col-sm-6">
        <div class="card border-0 shadow h-100 text-center p-4">
            <i class="bi bi-gavel text-primary fs-2 mb-3"></i>
            <h3 class="fw-bold">@Model.BuyerDashboard.TotalBids</h3>
            <small class="text-muted">Total Bids</small>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="card border-0 shadow h-100 text-center p-4">
            <i class="bi bi-trophy text-warning fs-2 mb-3"></i>
            <h3 class="fw-bold">@Model.BuyerDashboard.WonAuctions</h3>
            <small class="text-muted">Won Auctions</small>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="card border-0 shadow h-100 text-center p-4">
            <i class="bi bi-clock text-info fs-2 mb-3"></i>
            <h3 class="fw-bold">@Model.BuyerDashboard.ActiveBids</h3>
            <small class="text-muted">Active Bids</small>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="card border-0 shadow h-100 text-center p-4">
            <i class="bi bi-heart text-danger fs-2 mb-3"></i>
            <h3 class="fw-bold">@Model.BuyerDashboard.Watchlist</h3>
            <small class="text-muted">Watchlist</small>
        </div>
    </div>
    <div class="col-md-2 col-sm-6">
        <div class="card border-0 shadow h-100 text-center p-4">
            <i class="bi bi-currency-dollar text-success fs-2 mb-3"></i>
            <h3 class="fw-bold">$@Model.BuyerDashboard.TotalSpent:N0</h3>
            <small class="text-muted">Total Spent</small>
        </div>
    </div>
</div>
