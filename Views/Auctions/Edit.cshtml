@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Auction & Listing";
}

<section class="page create-listings-page">
    <h1>Edit Listing & Auction</h1>

    <div id="message" class="muted"></div>

    <div class="forms-root">
        <div class="listing-card">
            <form id="editForm">
                <h3>Listing</h3>
                <label>Title</label>
                <input name="title" required />

                <label>Description</label>
                <textarea name="description" rows="3"></textarea>

                <div class="row">
                    <div>
                        <label>Year</label>
                        <select name="year" required></select>
                    </div>
                    <div>
                        <label>Make</label>
                        <select name="makeId" required></select>
                    </div>
                    <div>
                        <label>Model</label>
                        <select name="modelId" required></select>
                    </div>
                </div>

                <div class="row">
                    <div>
                        <label>VIN</label>
                        <input name="vin" />
                    </div>
                    <div>
                        <label>Kilometers</label>
                        <input name="mileage" type="number" min="0" />
                    </div>
                    <div>
                        <label>Condition Grade</label>
                        <select name="conditionGrade">
                            <option value="5">5 - Excellent</option>
                            <option value="4">4 - Very Good</option>
                            <option value="3">3 - Good</option>
                            <option value="2">2 - Fair</option>
                            <option value="1">1 - Poor</option>
                        </select>
                    </div>
                </div>

                <h3>Location</h3>
                <label>City</label>
                <input name="city" required />
                <div class="row">
                    <div>
                        <label>Region</label>
                        <input name="region" />
                    </div>
                    <div>
                        <label>Country</label>
                        <input name="country" required />
                    </div>
                    <div>
                        <label>Postal Code</label>
                        <input name="postalCode" />
                    </div>
                </div>

                <hr />
                <h3>Auction</h3>
                <label>Starting Price</label>
                <input name="startPrice" type="number" step="0.01" />

                <label>Reserve Price</label>
                <input name="reservePrice" type="number" step="0.01" />

                <label>Auction End (local)</label>
                <input name="endTime" type="datetime-local" />

                <div style="margin-top:12px; display:flex; gap:8px;">
                    <button id="saveBtn" class="btn">Save all changes</button>
                    <a class="btn btn-outline" href="/Seller/Dashboard">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

<script src="/js/auction-edit.js"></script>