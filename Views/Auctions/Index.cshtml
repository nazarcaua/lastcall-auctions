@model IEnumerable<LastCallMotorAuctions.API.DTOs.AuctionBrowseDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Browse Auctions";
    var watchlistIds = (HashSet<int>)(ViewBag.WatchlistIds ?? new HashSet<int>());
    var isBuyer = (bool)(ViewBag.IsBuyer ?? false);
}

<link rel="stylesheet" href="~/css/auctions-browse.css" asp-append-version="true" />

<section class="page auctions-browse-page">
    <h1>Browse Auctions</h1>

    @if (Model == null || !Model.Any())
    {
        <p class="muted">No active auctions found.</p>
    }
    else
    {
        // Group auctions by their auction group (or treat individual auctions as their own group)
        var grouped = Model.GroupBy(a => a.AuctionGroupId ?? -a.AuctionId).ToList();

        <div class="auctions-list">
            @foreach (var group in grouped)
            {
                var first = group.First();
                var auctionTitle = first.AuctionGroupTitle ?? first.Title;
                var vehicleCount = group.Count();
                var startDate = group.Min(a => a.StartTime);
                var endDate = group.Max(a => a.EndTime);
                var firstPhoto = group.SelectMany(a => a.PhotoUrls).FirstOrDefault();
                var isWatchlisted = group.Any(a => watchlistIds.Contains(a.AuctionId));

                var timeRemaining = endDate - DateTime.UtcNow;
                var hasStarted = startDate <= DateTime.UtcNow;
                var hasEnded = timeRemaining.TotalSeconds <= 0;
                var isEndingSoon = timeRemaining.TotalHours < 24 && timeRemaining.TotalSeconds > 0;

                <article class="auction-event-card">
                    <!-- Photo Section -->
                    <div class="event-photo-section">
                        @if (firstPhoto != null)
                        {
                            <img class="event-photo" src="@firstPhoto" alt="@auctionTitle" />
                        }
                        else
                        {
                            <div class="event-photo-placeholder">No preview</div>
                        }
                        <div class="event-status-badge @(hasEnded ? "ended" : isEndingSoon ? "ending-soon" : hasStarted ? "active" : "upcoming")">
                            @(hasEnded ? "Ended" : isEndingSoon ? "Ending Soon" : hasStarted ? "Live" : "Upcoming")
                        </div>
                    </div>

                    <!-- Info Section -->
                    <div class="event-info-section">
                        <h2 class="event-title">@auctionTitle</h2>

                        <div class="event-vehicle-count">
                            <span class="vehicle-icon">🚗</span>
                            <span>@vehicleCount @(vehicleCount == 1 ? "Vehicle" : "Vehicles")</span>
                        </div>

                        <div class="event-dates">
                            <div class="date-row">
                                <span class="date-label">Starts</span>
                                <span class="date-value">@startDate.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</span>
                            </div>
                            <div class="date-row">
                                <span class="date-label">Ends</span>
                                <span class="date-value">@endDate.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</span>
                            </div>
                        </div>

                        <a class="btn event-view-btn" href="/Auctions/Detail/@(first.AuctionGroupId ?? first.AuctionId)">
                            View Auction
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</section>
