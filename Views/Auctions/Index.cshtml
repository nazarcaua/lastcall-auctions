@model IEnumerable<LastCallMotorAuctions.API.DTOs.AuctionBrowseDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Auctions";
}

<section class="page">
    <h1>Browse Auctions</h1>

    @if (Model == null || !Model.Any())
    {
        <p class="muted">No active auctions found.</p>
    }
    else
    {
        <div class="grid">
            @foreach (var auction in Model)
            {
                var listingTitle = auction.Title ?? "Listing";
                var makeModel = string.Join(" ", new[] { auction.MakeName, auction.ModelName }.Where(s => !string.IsNullOrWhiteSpace(s)));
                var displayPrice = auction.CurrentBid.HasValue ? string.Format("{0:C}", auction.CurrentBid.Value) : string.Format("{0:C}", auction.StartPrice);
                <article class="card">
                    <h3>@listingTitle (@auction.Year)</h3>
                    <p>@makeModel</p>
                    <p>@(auction.EndTime > DateTime.UtcNow ? $"Ends {auction.EndTime.ToLocalTime():g}" : "Ended")</p>
                    <p><strong>@(auction.CurrentBid.HasValue ? "Current bid:" : "Start price:")</strong> @displayPrice</p>
                    <a class="btn small" href="/Browse/Detail/@auction.AuctionId">View listing</a>
                </article>
            }
        </div>
    }
</section>
