@using Microsoft.AspNetCore.Identity
@using LastCallMotorAuctions.API.Models
@inject UserManager<User> UserManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - LastCall</title>
    @if (User.IsInRole("Buyer"))
    {
        <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    }
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-left">
            <a class="brand" href="/">LastCall</a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/Auctions">Auctions</a>
                <a href="/Home/VehicleValue">Vehicle Value</a>
                <a href="/Home/Policies">Policies</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Buyer"))
                    {
                        <a href="/Buyer/Dashboard">Buyer Dashboard</a>
                    }
                    @if (User.IsInRole("Seller"))
                    {
                        <a href="/Seller/Dashboard">Seller Dashboard</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard">Admin Dashboard</a>
                    }
                }
            </div>
        </div>

        <div class="nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                User? currentUser = null;
                try { currentUser = await UserManager.GetUserAsync(User); } catch { }
                var profilePic = currentUser?.ProfilePictureUrl;
                var userId = currentUser?.Id ?? 0;
                var displayName = currentUser?.FullName ?? User.Identity?.Name;
                <span class="nav-user">@displayName</span>
                @if (User.IsInRole("Buyer"))
                {
                    <div class="nav-bell-wrap">
                        <button class="nav-bell-btn" type="button" aria-label="Notifications" id="navBellBtn">
                            <svg class="nav-bell-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                            </svg>
                        </button>
                        <div class="nav-notification-popup" id="navNotificationPopup">
                            <div class="nav-notification-header">
                                <span class="nav-notification-title">Notifications</span>
                            </div>
                            <div class="nav-notification-list">
                                <div style="padding: 24px 16px; text-align: center; font-size: 13px; color: var(--color-muted);">
                                    No notifications yet.
                                </div>
                            </div>
                            <div class="nav-notification-footer">
                                <a href="/Notifications">View all notifications</a>
                            </div>
                        </div>
                    </div>
                }
                <div class="nav-profile-dropdown">
                    <button class="nav-avatar-btn" type="button" aria-label="Profile menu">
                        @if (!string.IsNullOrEmpty(profilePic))
                        {
                            <img class="nav-avatar" src="@profilePic" alt="Profile" />
                        }
                        else
                        {
                            <span class="nav-avatar-initials">@(string.IsNullOrEmpty(displayName) ? "?" : displayName[0].ToString().ToUpper())</span>
                        }
                    </button>
                    <div class="nav-dropdown-menu">
                        <a href="/Profile/@userId">View Profile</a>
                        <a href="/Profile/Edit">Edit Profile</a>
                        <hr />
                        <a href="/Auth/Logout">Logout</a>
                    </div>
                </div>
            }
            else
            {
                <a href="/Auth/Login">Login</a>
                <a href="/Auth/Register">Register</a>
            }
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Watchlist toggle (AJAX, buyer-only)
        function toggleWatchlist(btn) {
            var token = document.querySelector('meta[name="csrf-token"]');
            if (!token) return;
            var auctionId = btn.dataset.auctionId;
            btn.disabled = true;
            fetch('/Buyer/Watchlist/Toggle/' + auctionId, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token.content,
                    'Accept': 'application/json'
                }
            })
            .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
            .then(function(data) {
                btn.classList.toggle('active', data.isFavourited);
                btn.title = data.isFavourited ? 'Remove from watchlist' : 'Add to watchlist';
                if (btn.classList.contains('watchlist-text-btn')) {
                    btn.textContent = data.isFavourited ? '\u2665 Watching' : '\u2661 Watch';
                } else {
                    btn.textContent = data.isFavourited ? '\u2665' : '\u2661';
                }
            })
            .catch(function() {})
            .finally(function() { btn.disabled = false; });
        }

        // Profile dropdown + bell notification toggle
        document.addEventListener('DOMContentLoaded', function () {
            var avatarBtn = document.querySelector('.nav-avatar-btn');
            var profileMenu = document.querySelector('.nav-dropdown-menu');
            var bellBtn = document.getElementById('navBellBtn');
            var bellPopup = document.getElementById('navNotificationPopup');

            if (avatarBtn && profileMenu) {
                avatarBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    profileMenu.classList.toggle('show');
                    if (bellPopup) bellPopup.classList.remove('show');
                });
            }

            if (bellBtn && bellPopup) {
                bellBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    bellPopup.classList.toggle('show');
                    if (profileMenu) profileMenu.classList.remove('show');
                });
            }

            document.addEventListener('click', function () {
                if (profileMenu) profileMenu.classList.remove('show');
                if (bellPopup) bellPopup.classList.remove('show');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
