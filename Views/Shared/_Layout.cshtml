@using Microsoft.AspNetCore.Identity
@using LastCallMotorAuctions.API.Models
@inject UserManager<User> UserManager
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - LastCall</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar">
        <div class="nav-left">
            <a class="brand" href="/">LastCall</a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/Auctions">Auctions</a>
                <a href="/Home/VehicleValue">Vehicle Value</a>
                <a href="/Home/Policies">Policies</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Seller"))
                    {
                        <a href="/Seller/Dashboard">Seller Dashboard</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard">Admin Dashboard</a>
                    }
                }
            </div>
        </div>

        <div class="nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                User? currentUser = null;
                try { currentUser = await UserManager.GetUserAsync(User); } catch { }
                var profilePic = currentUser?.ProfilePictureUrl;
                var userId = currentUser?.Id ?? 0;
                var displayName = currentUser?.FullName ?? User.Identity?.Name;
                <span class="nav-user">@displayName</span>
                <div class="nav-profile-dropdown">
                    <button class="nav-avatar-btn" type="button" aria-label="Profile menu">
                        @if (!string.IsNullOrEmpty(profilePic))
                        {
                            <img class="nav-avatar" src="@profilePic" alt="Profile" />
                        }
                        else
                        {
                            <span class="nav-avatar-initials">@(string.IsNullOrEmpty(displayName) ? "?" : displayName[0].ToString().ToUpper())</span>
                        }
                    </button>
                    <div class="nav-dropdown-menu">
                        <a href="/Profile/@userId">View Profile</a>
                        <a href="/Profile/Edit">Edit Profile</a>
                        <hr />
                        <a href="/Auth/Logout">Logout</a>
                    </div>
                </div>
            }
            else
            {
                <a href="/Auth/Login">Login</a>
                <a href="/Auth/Register">Register</a>
            }
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Profile dropdown toggle
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.querySelector('.nav-avatar-btn');
            var menu = document.querySelector('.nav-dropdown-menu');
            if (btn && menu) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    menu.classList.toggle('show');
                });
                document.addEventListener('click', function () {
                    menu.classList.remove('show');
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
