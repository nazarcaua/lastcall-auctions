@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<section class="home">
    <h1>LastCall Motor Auctions</h1>

    <p>
        A secure, real-time automotive auction platform designed to modernize traditional vehicle auctions.
        Bid or sell vehicles from anywhere, with a focus on transparency, verification, and nationwide access.
    </p>

    <div class="highlights">
        <h3>What this platform aims to provide</h3>
        <ul>
            <li><strong>Real-time bidding</strong> with accurate time synchronization</li>
            <li><strong>Buyer and seller roles</strong> (buyers by default, sellers require approval)</li>
            <li><strong>Vehicle transparency</strong> through inspections and condition reporting</li>
            <li><strong>Market value insights</strong> planned via Kelley Blue Book integration</li>
            <li><strong>Vehicle verification</strong> planned via VIN auditing</li>
            <li><strong>Secure payments</strong> with pre-authorization (planned)</li>
        </ul>
    </div>

</section>
