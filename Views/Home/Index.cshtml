@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<section class="home page">
    <div class="hero">
        <h1>Buy &amp; Sell Vehicles at Auction — From Anywhere</h1>
        <p class="hero-sub">
            LastCall Motor Auctions is a real-time online platform where buyers bid on inspected vehicles
            and sellers reach a nationwide audience. Transparent pricing, verified condition reports,
            and live bidding — all in one place.
        </p>
        <div class="cta">
            <a class="btn accent" href="/Auctions">Browse Auctions</a>
            <a class="btn outline" href="/Auth/Register">Create an Account</a>
        </div>
    </div>

    <div class="how-it-works">
        <h2>How It Works</h2>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3>Browse Listings</h3>
                <p>Explore active auctions with detailed vehicle information, photos, and condition grades.</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h3>Place Your Bid</h3>
                <p>Bid in real time with live updates. You'll always know where you stand before the auction closes.</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h3>Win &amp; Complete</h3>
                <p>If you're the highest bidder when the auction ends, the vehicle is yours. Secure payment and pickup details follow.</p>
            </div>
        </div>
    </div>

    <div class="features-section">
        <h2>Why LastCall?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3>Real-Time Bidding</h3>
                <p>Live bid updates powered by SignalR so you never miss a beat during an auction.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h3>Vehicle Transparency</h3>
                <p>Every listing includes a condition grade, mileage, photos, and a detailed description — no surprises.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛡️</div>
                <h3>Verified Sellers</h3>
                <p>Sellers are approved before listing. Buyers can bid with confidence knowing vehicles are vetted.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📍</div>
                <h3>Nationwide Access</h3>
                <p>No need to attend in person. Browse, bid, and buy from anywhere across the country.</p>
            </div>
        </div>
    </div>

    <div class="home-sellers">
        <div class="highlights">
            <h3>Are You a Seller?</h3>
            <p>
                List your vehicles in auction groups, upload photos, set starting prices and optional reserve prices,
                and let buyers compete in real time. Track everything from your Seller Dashboard.
            </p>
            <div class="cta" style="margin-top: 16px;">
                <a class="btn" href="/Auth/Register">Register as a Seller</a>
            </div>
        </div>
    </div>

    <p class="note">
        LastCall Motor Auctions — bringing the auction floor to your screen.
    </p>
</section>
