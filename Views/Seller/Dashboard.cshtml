@using LastCallMotorAuctions.API.Models
@using LastCallMotorAuctions.API.ViewModels
@model SellerDashboardViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Seller Dashboard";
    var now = DateTime.UtcNow;
}

<div class="dashboard-header">
    <h1>Seller Dashboard</h1>
    <p class="muted">Welcome back, @Model.SellerName! Manage your listings, track activity, and review sales.</p>
</div>

@if (ViewBag.DbError != null)
{
    <div class="alert alert-warning">
        @ViewBag.DbError
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="dashboard-cards">
    <div class="card">
        <div class="card-label">Total Listings</div>
        <div class="card-value">@Model.TotalListings</div>
        <div class="card-sub">All time</div>
    </div>

    <div class="card">
        <div class="card-label">Active Listings</div>
        <div class="card-value">@Model.ActiveListings</div>
        <div class="card-sub">Currently running</div>
    </div>

    <div class="card">
        <div class="card-label">Ended Listings</div>
        <div class="card-value">@Model.EndedListings</div>
        <div class="card-sub">Finished auctions</div>
    </div>

    <div class="card">
        <div class="card-label">Total Bids</div>
        <div class="card-value">@Model.TotalBids</div>
        <div class="card-sub">Across all auctions</div>
    </div>

    <div class="card">
        <div class="card-label">Revenue</div>
        <div class="card-value">$@Model.TotalRevenue.ToString("N2")</div>
        <div class="card-sub">From completed payments</div>
    </div>

    <div class="card">
        <div class="card-label">Needs Attention</div>
        <div class="card-value">@Model.NeedsAttentionCount</div>
        <div class="card-sub">Reserve not met / no winner</div>
    </div>
</div>

<div class="dashboard-actions">
    <a class="btn" href="/Listings/Create">Create New Listing</a>
</div>

<hr class="divider" />

<div class="section">
    <div class="section-header">
        <h2>Active Auctions</h2>
        <p class="muted">Your auctions that are currently running (grouped).</p>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Group</th>
                <th>Vehicles</th>
                <th>Start Price</th>
                <th>Reserve</th>
                <th>Ends</th>
                <th>Time Left</th>
                <th>Status</th>
                <th style="width:160px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var activeGroups = (Model.AuctionGroups ?? new List<AuctionGroupViewModel>())
                    .Where(g => g.Auctions.Any(a => a.StartTime <= now && a.EndTime > now))
                    .OrderBy(g => g.Auctions.Min(a => a.EndTime))
                    .ToList();

                if (!activeGroups.Any())
                {
                    <tr>
                        <td colspan="8" class="muted">No active auctions yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var g in activeGroups)
                    {
                        var ends = g.Auctions.Min(a => a.EndTime);
                        var startPrice = g.Auctions.Min(a => a.StartPrice);
                        var reserve = g.Auctions.Where(a => a.ReservePrice.HasValue).Select(a => a.ReservePrice.Value).DefaultIfEmpty().Min();
                        var timeLeft = ends - now;
                        var timeLeftText = timeLeft.TotalSeconds <= 0 ? "Ended" : $"{(int)timeLeft.TotalDays}d {timeLeft.Hours}h {timeLeft.Minutes}m";

                        <tr>
                            <td>@g.Title</td>
                            <td>@(g.Auctions.Count) vehicles</td>
                            <td>$@startPrice.ToString("N2")</td>
                            <td>@(reserve > 0 ? $"${reserve:N2}" : "-")</td>
                            <td>@ends.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@timeLeftText</td>
                            <td>@(g.Auctions.First().Status?.Name ?? $"StatusId: {g.Auctions.First().StatusId}")</td>
                            <td>
                                <a class="link" href="/Auctions/Detail/@(g.AuctionGroupId ?? g.GroupKey)">View</a>
                                <span class="sep">|</span>
                                <a class="link" href="/Auctions/Edit/@(g.GroupKey)">Edit</a>
                                <span class="sep">|</span>
                                <form method="post" action="/Auctions/End/@(g.GroupKey)" style="display:inline;" onsubmit="return confirm('End this auction now? This cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="delete-btn">End</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>

<div class="section">
    <div class="section-header">
        <h2>Recently Ended</h2>
        <p class="muted">Your most recently ended auctions.</p>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Auction ID</th>
                <th>Vehicle</th>
                <th>Start Price</th>
                <th>Reserve</th>
                <th>Ended</th>
                <th>Status</th>
                <th style="width:200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var ended = (Model.Auctions ?? new List<Auction>())
                .Where(a => a.EndTime <= now)
                .OrderByDescending(a => a.EndTime)
                .Take(5)
                .ToList();

                if (!ended.Any())
                {
                    <tr>
                        <td colspan="7" class="muted">No ended auctions yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var a in ended)
                    {
                        var vehicleTitle = a.Listing != null 
                            ? $"{a.Listing.Year} {a.Listing.Make?.Name ?? ""} {a.Listing.Model?.Name ?? ""}"
                            : $"Listing #{a.ListingId}";

                        <tr>
                            <td>@a.AuctionId</td>
                            <td>@vehicleTitle</td>
                            <td>$@a.StartPrice.ToString("N2")</td>
                            <td>@(a.ReservePrice.HasValue ? $"${a.ReservePrice.Value:N2}" : "-")</td>
                            <td>@a.EndTime.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@(a.Status?.Name ?? $"StatusId: {a.StatusId}")</td>
                            <td>
                                <a class="link" href="/Auctions/Details/@a.AuctionId">View</a>
                                <span class="sep">|</span>
                                <a class="link" href="/Seller/Sales">Sale Details</a>
                                <span class="sep">|</span>
                                <form method="post" action="/Seller/DeleteAuction" style="display:inline;" onsubmit="return confirm('Permanently delete this auction and all its history?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="auctionId" value="@a.AuctionId" />
                                    <button type="submit" class="delete-btn">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>
